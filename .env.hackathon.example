# .env.hackathon.example — copy to .env.hackathon on the MI300X cloud node
#
# Source before running orchestrator / docker compose:
#   set -a; source .env.hackathon; set +a
#
# .env.hackathon itself is gitignored. Only this template is committed.

# ── LLM provider selection ──────────────────────────────────────────────────
LLM_PROVIDER=vllm

# ── Orchestrator-tier vLLM (Qwen, Opus-equivalent) ──────────────────────────
# Orchestrator process runs natively on the host and reaches vLLM via the
# host port binding (127.0.0.1:18000 -> container 8000). Inside the docker
# network, other containers should use http://vllm-orchestrator:8000/v1.
VLLM_BASE_URL=http://127.0.0.1:18000/v1
VLLM_ORCHESTRATOR_MODEL=Qwen/Qwen3.5-27B
VLLM_ORCHESTRATOR_MEM_UTIL=0.40
VLLM_ORCHESTRATOR_MAX_MODEL_LEN=16384

# ── Agent-tier vLLM (Qwen, Haiku-equivalent) ────────────────────────────────
# MiroFish (in-container) reaches this via http://vllm-agents:8001/v1
# (already wired in docker-compose.rocm.yml). The host-side URL is here for
# debugging / direct curl from the cloud VM.
VLLM_AGENT_BASE_URL=http://127.0.0.1:18001/v1
VLLM_AGENT_MODEL=Qwen/Qwen3.5-9B
VLLM_AGENT_MEM_UTIL=0.40
VLLM_AGENT_MAX_MODEL_LEN=8192

# ── Fallback pair (Qwen3 dense, April 2025) ─────────────────────────────────
# Trigger conditions in docs/competition/MODELS.md. To use the fallback:
#   1. Comment out the four VLLM_*_MODEL lines above
#   2. Uncomment the four lines below
#   3. docker compose ... up -d --force-recreate vllm-orchestrator vllm-agents
# VLLM_ORCHESTRATOR_MODEL=Qwen/Qwen3-32B
# VLLM_ORCHESTRATOR_MAX_MODEL_LEN=16384
# VLLM_AGENT_MODEL=Qwen/Qwen3-8B
# VLLM_AGENT_MAX_MODEL_LEN=8192

# ── vLLM image tag ──────────────────────────────────────────────────────────
# Default in compose is rocm/vllm:latest. Override here to pin a specific
# tag once Phase 3 confirms which one works (the AMD Quick Start image
# may ship a specific build).
# VLLM_IMAGE=rocm/vllm:latest
VLLM_LOG_LEVEL=INFO

# ── HuggingFace ─────────────────────────────────────────────────────────────
# Required by scripts/prefetch_models.sh AND by both vLLM containers if they
# need to download weights on first start (which they will on a fresh node).
HF_TOKEN=hf_REPLACE_ME

# ── TRIBE v2 ────────────────────────────────────────────────────────────────
# ROCm PyTorch presents AMD GPUs as device="cuda" — no string change needed.
TRIBE_DEVICE=cuda
TRIBE_MODEL_PATH=facebook/tribev2

# ── Existing stack vars (carry over from base .env) ─────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme-use-a-strong-password
ORCHESTRATOR_PORT=8000

# ── Notes ───────────────────────────────────────────────────────────────────
# - The Anthropic-side env vars (ANTHROPIC_API_KEY, CLAUDE_*_MODEL,
#   CLAUDE_CREDENTIALS_PATH) are intentionally NOT set here — LLM_PROVIDER=vllm
#   means the orchestrator never reaches for them.
# - LiteLLM is bypassed entirely on this stack (MiroFish points directly at
#   vllm-agents). The base docker-compose.yml still defines a litellm
#   service but the rocm overlay's mirofish override doesn't depend on it.
