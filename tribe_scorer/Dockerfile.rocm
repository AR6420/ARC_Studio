# TRIBE v2 scorer — ROCm image for AMD MI300X (hackathon target).
#
# Base: rocm/pytorch:rocm6.2_ubuntu22.04_py3.11_pytorch_2.5.1
#   - matches the torch>=2.5.1,<3.0 pin from requirements.txt
#   - Python 3.11 satisfies pyannote.audio's pin (transitive via legacy
#     whisperx; we no longer use whisperx but the constraint still
#     applies if anything else pulls pyannote in)
#   - PyTorch presents AMD GPUs as device="cuda", so the rest of TRIBE's
#     device handling needs no string changes
#
# This image only contains the TRIBE scorer + its dependencies. vLLM
# runs in a separate container (Phase 2) so model lifecycles can be
# managed independently.

FROM rocm/pytorch:rocm6.2_ubuntu22.04_py3.11_pytorch_2.5.1

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    HF_HUB_DISABLE_TELEMETRY=1

WORKDIR /app

# System deps for ffmpeg (audio/video probing) and build essentials for
# any wheels that lack manylinux ROCm builds.
RUN apt-get update && apt-get install -y --no-install-recommends \
        ffmpeg \
        git \
        build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install Python deps. PyTorch is preinstalled in the base image at the
# matching version range, so we install the rest on top WITHOUT touching
# the torch/torchaudio wheels (would clobber the ROCm builds with CUDA
# builds from PyPI).
COPY requirements.txt ./requirements.txt
RUN pip install --upgrade pip wheel setuptools \
    && grep -vE '^(torch|torchaudio)\b' requirements.txt > /tmp/req-no-torch.txt \
    && pip install -r /tmp/req-no-torch.txt

# Copy the scorer service source and the vendored TRIBE v2 package.
COPY . /app/tribe_scorer
RUN pip install -e /app/tribe_scorer/vendor/tribev2

ENV TRIBE_DEVICE=cuda \
    TRIBE_MODEL_PATH=facebook/tribev2 \
    HF_HOME=/cache/hf \
    TRIBE_CACHE_FOLDER=/cache/tribe

EXPOSE 8001

# Run from the package root so `from config import settings` resolves.
WORKDIR /app/tribe_scorer
CMD ["python", "-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8001"]
